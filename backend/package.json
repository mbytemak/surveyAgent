{
  "name": "survey-analytics-backend",
  "version": "1.0.0",
  "description": "Survey comment analytics with AI agent",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc",
    "postinstall": "npm run build",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "migrate": "ts-node migrations/001_init.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.0.0",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/pg": "^8.10.7",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
